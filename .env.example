# Local dev: open only http://localhost:3000 in the browser. Next.js API routes on :3000 call the
# Python API using BACKEND_URL below (server-to-server); you do not need to open :8000 for normal use.
#
# GitHub OAuth App (https://github.com/settings/developers) must list this exact callback:
#   http://localhost:3000/api/auth/callback/github
# If the browser shows "localhost:3001 not reached", either:
#   - NEXTAUTH_URL below still says :3001 → change it to match the port you use, OR
#   - The GitHub OAuth "Authorization callback URL" is still :3001 → change it to :3000 (or your real port).

# Next.js Configuration — must match the origin you open in the browser (scheme + host + port).
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# GitHub OAuth Configuration
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Backend Configuration
BACKEND_URL=http://localhost:8000

# Python backend (optional): set to enable PostgreSQL persistence for scans.
# Same DATABASE_URL is read by FastAPI when you run backend/main.py (loaded from this file or backend/.env).
# Use asyncpg driver. Example matches docker-compose.yml defaults:
# DATABASE_URL=postgresql+asyncpg://reposcanner:reposcanner@localhost:5432/reposcanner
# DATABASE_URL=

# Comma-separated origins for FastAPI CORS (default: http://localhost:3000)
# FRONTEND_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# --- Hosted / production (nothing is "hardcoded" in code for your domain — set these where you deploy) ---
# Frontend (e.g. Vercel): NEXTAUTH_URL=https://your-domain.com
#                         BACKEND_URL=https://your-python-api.example.com
#                         Same GitHub OAuth app: add callback https://your-domain.com/api/auth/callback/github
# Python API host:         FRONTEND_ORIGINS=https://your-domain.com
# (Optional) DATABASE_URL on the API host for Postgres (e.g. AWS RDS):
#   postgresql+asyncpg://USER:PASS@your-rds.region.rds.amazonaws.com:5432/reposcanner?ssl=true
